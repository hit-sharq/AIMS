// Jitume AIMS — AI-Driven Talent Marketplace & Matchmaking Platform
// Prisma Schema Definition

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum UserRole {
  CLIENT
  CREATOR
  ADMIN
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum AvailabilityStatus {
  IMMEDIATE
  PART_TIME
  FULL_TIME
  UNAVAILABLE
}

enum JobStatus {
  ACTIVE       // Scanning for creator
  MATCHING     // Top creators matched, awaiting admin/creator response
  ASSIGNED     // Creator accepted & matched
  COMPLETED    // Work finished
  CANCELLED
}

enum MatchStatus {
  AI_PROPOSED          // Generated by AI comparison engine
  ADMIN_APPROVED       // Verified by Admin/Committee
  ACCEPTED_BY_CREATOR  // Creator accepted the match
  DECLINED_BY_CREATOR  // Creator declined the match
  REJECTED_BY_ADMIN    // Admin rejected the match
}

// -----------------------------------------------------------------------------
// CORE MODELS
// -----------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole @default(CLIENT)
  avatarUrl String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Profile Relations
  clientProfile  ClientProfile?
  creatorProfile CreatorProfile?

  // Demand Relation (for Clients)
  clientJobs Job[] @relation("ClientJobs")

  // Oversight Relation (for Admins)
  approvedMatches Match[] @relation("AdminApprovedMatches")

  // Notifications
  notifications Notification[]
}

model ClientProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName        String?
  website            String?
  industry           String?
  accessibilityNeeds String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model CreatorProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String             // e.g., "Full-Stack Developer", "UI/UX Strategist"
  bio                String?
  level              ExperienceLevel    @default(MID)
  cvUrl              String?
  linkedInUrl        String?
  gitHubUrl          String?
  portfolioUrl       String?
  hourlyRate         Float?
  availability       AvailabilityStatus @default(IMMEDIATE)
  isVerified         Boolean            @default(false)
  aiTaggingSummary   String?            // AI-parsed capability summary
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  skills  CreatorSkill[]
  matches Match[]
}

model Skill {
  id        String   @id @default(cuid())
  name      String   @unique // e.g., "React", "Node.js", "PostgreSQL", "UI/UX", "Tailwind CSS"
  category  String?  // e.g., "Frontend", "Backend", "Design", "AI/ML"
  createdAt DateTime @default(now())

  creators CreatorSkill[]
  jobs     JobSkill[]
}

model CreatorSkill {
  id              String         @id @default(cuid())
  creatorId       String
  creator         CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  skillId         String
  skill           Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)
  weight          Int            @default(80) // 1 to 100 skill weight assigned by AI
  experienceYears Float?         @default(1.0)

  @@unique([creatorId, skillId])
}

model Job {
  id             String          @id @default(cuid())
  clientId       String
  client         User            @relation("ClientJobs", fields: [clientId], references: [id], onDelete: Cascade)
  title          String          // e.g., "E-Commerce Web Application"
  description    String          // Detailed client requirements from intake
  projectType    String          // e.g., "E-Commerce", "Mobile App", "AI Integration", "SaaS Platform"
  budgetMin      Float?
  budgetMax      Float?
  budgetCurrency String          @default("KES")
  timeline       String          // e.g., "4 Weeks", "12 Weeks"
  requiredLevel  ExperienceLevel @default(MID)
  status         JobStatus       @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  skills  JobSkill[]
  matches Match[]
}

model JobSkill {
  id         String   @id @default(cuid())
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  weight     Int      @default(80) // Required weight for AI comparison
  isRequired Boolean  @default(true)

  @@unique([jobId, skillId])
}

model Match {
  id                String         @id @default(cuid())
  jobId             String
  job               Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  creatorId         String
  creator           CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  confidenceScore   Float          // e.g., 95.4 (AI Confidence Score percentage)
  rank              Int            @default(1) // 1, 2, 3 ranked position
  status            MatchStatus    @default(AI_PROPOSED)
  aiReasoning       String?        // Detailed breakdown of why AI matched this creator
  approvedByAdminId String?
  approvedByAdmin   User?          @relation("AdminApprovedMatches", fields: [approvedByAdminId], references: [id])
  approvedAt        DateTime?
  respondedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([jobId, creatorId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  refId     String?  // Reference ID (e.g., jobId or matchId)
  createdAt DateTime @default(now())
}
